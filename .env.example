# Admin (obligatoire en production)
ADMIN_PASSWORD=changez-moi
ADMIN_SESSION_SECRET=changez-moi-32-caracteres-minimum!!

# MongoDB Atlas (obligatoire en production pour le back-office)
# Créez un cluster gratuit sur https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=bamboucamer
